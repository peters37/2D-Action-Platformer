                if slime3.x >= WIDTH - Slime_Width and Slime3_Facing_Right:
                    pygame.event.post(pygame.event.Event(Change_Slime3_Direction))
                elif slime3.x <= 0 and not Slime3_Facing_Right:
                    pygame.event.post(pygame.event.Event(Change_Slime3_Direction))
                elif Slime3_Facing_Right:
                    slime3.x += Slime_Vel
                else:
                    slime3.x -= Slime_Vel
            if slime4.y >= Ground_Height - Slime_Height:
                if slime4.x >= WIDTH - Slime_Width and Slime4_Facing_Right:
                    pygame.event.post(pygame.event.Event(Change_Slime4_Direction))
                elif slime4.x <= 0 and not Slime4_Facing_Right:
                    pygame.event.post(pygame.event.Event(Change_Slime4_Direction))
                elif Slime4_Facing_Right:
                    slime4.x += Slime_Vel
                else:
                    slime4.x -= Slime_Vel
            if (character.colliderect(slime1) or character.colliderect(slime2) or character.colliderect(slime3) or character.colliderect(slime4)) and character_invincibility_frames_counter > Invincibility_Frames: ## If the character collides with the slime, he loses health and is moved in the opposite direction to the one he is facing
                pygame.event.post(pygame.event.Event(Protagonist_Lose_Health))
                pygame.event.post(pygame.event.Event(Reset_Invincibility_Frames_Counter))
                if Protagonist_Facing_Right:
                    character.x -= Character_Fallback
                    sword.x -= Character_Fallback
                else:
                    character.x += Character_Fallback
                    sword.x += Character_Fallback
        if phase2_completed:
            if minotaur.y - 15 < Ground_Height - Minotaur_Height: ## 15 is subtracted here because the height of the minotaur's rectangle is different than its image
                minotaur.y += Character_Vel ## Minotaur falls down until it hits the ground
            if minotaur.y - 15 >= Ground_Height - Minotaur_Height: ## 15 is subtracted here because the height of the minotaur's rectangle is different than its image
                if minotaur_attack_frame_counter > Minotaur_Attack_Frames: ## Enough frames have passed, so the minotaur starts to attack
                    pygame.event.post(pygame.event.Event(Update_Minotaur_Attacking))
                if minotaur_attacking:
                    if minotaur_attack_frame_counter >= Minotaur_Animation_Frames: ## If not enough frames have passed, the minotaur will stay in its attack animation, if enough frames have passed, his attack will end
                        pygame.event.post(pygame.event.Event(Update_Minotaur_Attacking))
                pygame.event.post(pygame.event.Event(Increase_Minotaur_Attack_Frame_Counter))
                pygame.event.post(pygame.event.Event(Update_Minotaur_Pic))
                if not minotaur_attacking and character.x - 10 + 30 < minotaur.x: ## Minotaur moves left and right depending on the location of the character. He will stop within 30 units of the character
                    minotaur.x -= Minotaur_Vel
                    pygame.event.post(pygame.event.Event(Minotaur_Moving_Left))
                elif not minotaur_attacking and character.x - 10 - 30 > minotaur.x:
                    minotaur.x += Minotaur_Vel
                    pygame.event.post(pygame.event.Event(Minotaur_Moving_Right))
            if character.colliderect(minotaur) and character_invincibility_frames_counter > Invincibility_Frames:
                pygame.event.post(pygame.event.Event(Protagonist_Lose_Health))
                pygame.event.post(pygame.event.Event(Reset_Invincibility_Frames_Counter))
                if Minotaur_Facing_Left and minotaur_attacking: ## The character will fallback in the direction that the minotaur faces
                    if character.x - Character_Fallback*2 > 0:
                        character.x -= Character_Fallback*2
                        sword.x -= Character_Fallback*2
                    elif Protagonist_Facing_Right:
                        character.x = 10
                        sword.x = Protagonist_Width - 9
                    else:
                        character.x = 10
                        sword.x = -10
                elif Minotaur_Facing_Left and not minotaur_attacking: ## If the character collides with the minotaur when it is not attacking, the character will fall back in the opposite direction of the one he faces
                    if Protagonist_Facing_Right:
                        if character.x - Character_Fallback > 0:
                            character.x -= Character_Fallback
                            sword.x -= Character_Fallback
                        else:
