## This function draws things on to the screen
def draw_window(character, sword, Sword_pic, slime1, slime1_health, slime2, slime2_health, slime3, slime3_health, slime4, slime4_health, protagonist_health, bird, Bird_pic, projectile, Protagonist_Pic, heart, heart_collected, level, rock_ledge3, rock_ledge6, dog, Dog_pic, dog_health, ghost1, ghost1_health, ghost2, ghost2_health, Ghost1_Pic, Ghost2_Pic, ghost_frame_counter, phase1_completed, Slime1_Pic, Slime2_Pic, Slime3_Pic, Slime4_Pic, minotaur, phase2_completed, Minotaur_Pic, minotaur_health, arrow_sign, phase4_completed, final_boss, Boss_Pic, boss_health, fireball1, fireball2, fireball3, fireball4, fireball5, fireball6, fireball7, fireball8, fireball9, fireball10, Fireball_Pic, Boss_Disappearing, Boss_Attack2, Boss_Attack3):
    if level == 1:
        WIN.blit(Grassy_Background, (0, 0))
        WIN.blit(Ground_image, (0, Ground_Height)) ## The real Y-coordinate of the grass is 435
        WIN.blit(Grass_Ledge_image, (Grass_Ledge_X_Position, Grass_Ledge_Y_Position))
        WIN.blit(Grass_Ledge_image, (Grass_Ledge2_X_Position, Grass_Ledge2_Y_Position))
        WIN.blit(Grass_Ledge_image, (Grass_Ledge3_X_Position, Grass_Ledge3_Y_Position))
        WIN.blit(Long_Grass_Ledge_image, (Grass_Ledge4_X_Position, Grass_Ledge4_Y_Position))
        WIN.blit(Grass_Ledge_image, (Grass_Ledge5_X_Position, Grass_Ledge5_Y_Position))
        WIN.blit(Grass_Ledge_image, (Grass_Ledge6_X_Position, Grass_Ledge6_Y_Position))
        WIN.blit(Arrow_image, (Arrow_Sign_X_Position, Arrow_Sign_Y_Position))
        if not heart_collected: ## Once heart is collected, it is no longer drawn to the screen
            WIN.blit(Heart_image, (heart.x, heart.y))
        if slime1_health > 0:
            WIN.blit(Slime1_Pic, (slime1.x, slime1.y))
        if slime2_health > 0:
            WIN.blit(Slime2_Pic, (slime2.x, slime2.y))
        if slime3_health > 0:
            WIN.blit(Slime3_Pic, (slime3.x, slime3.y))
        WIN.blit(Bird_pic, (bird.x, bird.y))
        WIN.blit(Bomb_image, (projectile.x+5, projectile.y))
    if level == 2:
        WIN.blit(Cave_Background_image, (0, 0))
        WIN.blit(Rock_Ledge_image, (Rock_Ledge_X_Position, Rock_Ledge_Y_Position))
        WIN.blit(Rock_Ledge_image, (Rock_Ledge2_X_Position, Rock_Ledge2_Y_Position))
        WIN.blit(Rock_Ledge_image, (rock_ledge3.x, rock_ledge3.y))
        WIN.blit(Rock_Ledge_image, (Rock_Ledge4_X_Position, Rock_Ledge4_Y_Position))
        WIN.blit(Rock_Ledge_image, (Rock_Ledge5_X_Position, Rock_Ledge5_Y_Position))
        WIN.blit(Rock_Ledge_image, (rock_ledge6.x, rock_ledge6.y))
        WIN.blit(Rock_Ledge_image, (Rock_Ledge7_X_Position, Rock_Ledge7_Y_Position))
        WIN.blit(Rock_image, (0, Ground_Height))
        WIN.blit(Rock_image2, (High_Rock_Path_X_Position, High_Rock_Path_Y_Position)) ## Represents the rock in the high path with the dog
        WIN.blit(Rock_image3, (100, 460)) ## Represents the rock underneath the lava
        WIN.blit(Wall_image, (Wall_X_Position, Wall_Y_Position))
        WIN.blit(lava_image, (Lava_X_Position, Lava_Y_Position))
        WIN.blit(Rotated_Arrow_image, (930, 400))
        if dog_health > 0: ## Once the dog dies, it is no longer drawn to the screen
            WIN.blit(Dog_pic, (dog.x, dog.y))
    if level == 3:
        WIN.blit(Dungeon_Background_image, (0, 0))
        WIN.blit(Dungeon_Floor_image, (0, Ground_Height))
        if not phase1_completed:
            if ghost_frame_counter <= Ghost_Invisibility_Frames:
                if ghost1_health > 0: ## If the ghost dies, it is not drawn to the screen
                    WIN.blit(Ghost1_Pic, (ghost1.x, ghost1.y))
                if ghost2_health > 0:
                    WIN.blit(Ghost2_Pic, (ghost2.x, ghost2.y))
                pygame.event.post(pygame.event.Event(Update_Ghost_Frame_Counter))
            elif ghost_frame_counter >= Ghost_Invisibility_Frames*2:
                pygame.event.post(pygame.event.Event(Reset_Ghost_Frame_Counter))
            else:
                pygame.event.post(pygame.event.Event(Update_Ghost_Frame_Counter))
        elif phase1_completed:
            if slime1_health > 0:
                WIN.blit(Slime1_Pic, (slime1.x, slime1.y))
            if slime2_health > 0:
                WIN.blit(Slime2_Pic, (slime2.x, slime2.y))
            if slime3_health > 0:
                WIN.blit(Slime3_Pic, (slime3.x, slime3.y))
            if slime4_health > 0:
                WIN.blit(Slime4_Pic, (slime4.x, slime4.y))
        if phase2_completed:
            if minotaur_health > 0:
                WIN.blit(Minotaur_Pic, (minotaur.x, minotaur.y - 15))
        if phase4_completed: ## After all the enemies are defeated, the arrow sign will fall
            WIN.blit(Arrow_image, (arrow_sign.x, arrow_sign.y))
    if level == 4:
        WIN.blit(Final_Boss_Background_image, (0, 0))
        WIN.blit(Castle_Floor_image, (0, Ground_Height))
        if boss_health > 0:
            WIN.blit(Boss_Pic, (final_boss.x - 10, final_boss.y-20))
        if not Boss_Disappearing and not Boss_Attack3:
            WIN.blit(Fireball_Pic, (fireball1.x, fireball1.y))
            WIN.blit(Fireball_Pic, (fireball2.x, fireball2.y))
            if Boss_Attack2:
                WIN.blit(Fireball_Pic, (fireball3.x, fireball3.y))
                WIN.blit(Fireball_Pic, (fireball4.x, fireball4.y))
                WIN.blit(Fireball_Pic, (fireball5.x, fireball5.y))
                WIN.blit(Fireball_Pic, (fireball6.x, fireball6.y))
                WIN.blit(Fireball_Pic, (fireball7.x, fireball7.y))
                WIN.blit(Fireball_Pic, (fireball8.x, fireball8.y))
                WIN.blit(Fireball_Pic, (fireball9.x, fireball9.y))
                WIN.blit(Fireball_Pic, (fireball10.x, fireball10.y))
    if protagonist_health >= 4:
        WIN.blit(Heart_Health_image, (70, 0))
    if protagonist_health >= 3:
        WIN.blit(Heart_Health_image, (40, 0))
    if protagonist_health >= 2:
