                            sword.x = Protagonist_Width - 9
                    else:
                        character.x += Character_Fallback
                        sword.x += Character_Fallback
                else:
                    character.x += Character_Fallback
                    sword.x += Character_Fallback
        if phase4_completed: ## Arrow_Sign will fall until it hits the ground
            if arrow_sign.y < Ground_Height - Arrow_Sign_Height:
                arrow_sign.y += Character_Vel
    pygame.event.post(pygame.event.Event(Increase_Invincibility_Frames_Counter))

       
