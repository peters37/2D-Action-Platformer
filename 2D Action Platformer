## This function tells the code how to move the sword
def swordmovement(keys_pressed, swing, sword, slime1, slime2, slime3, slime4, Protagonist_Facing_Right, level, frame_counter, dog, ghost1, ghost2, minotaur, holding_shift, enemy_invincibility_frames_counter, final_boss, Boss_Disappearing, flying_final_boss, Boss_Attack3_Part1):
    if keys_pressed[pygame.K_RSHIFT] and swing == False and frame_counter >= Sword_Frame_Counter and not holding_shift: ## Tells the main function to rotate the sword down, but only once enough frames have passed to ensure the sword is not spammed too quickly
        pygame.time.delay(10) ## Sword will not swing if the shift button is being held down
        pygame.event.post(pygame.event.Event(Sword_Swing_Down))
        pygame.event.post(pygame.event.Event(Swing_True))
        pygame.event.post(pygame.event.Event(Reset_Frame_Counter)) ## Resets counter so the player will have to wait a certain amount of frames before using the sword again
    if swing == True and keys_pressed[pygame.K_RSHIFT]: ## The player is holding shift
        pygame.event.post(pygame.event.Event(Player_Holding_Shift))
    if not keys_pressed[pygame.K_RSHIFT]:
        pygame.event.post(pygame.event.Event(Player_Not_Holding_Shift))
    if swing == True: ## Tells the main function to rotate the sword back up
        if level == 1 or level == 3: ## slimes are only in level 1 and 3
            if sword.colliderect(slime1) and enemy_invincibility_frames_counter > Enemy_Invincibility_Frames: ## Damages the slime
                pygame.event.post(pygame.event.Event(Reset_Enemy_Invincibility_Frames_Counter))
