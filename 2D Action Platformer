        if bird.x == 0 and bird_facing_left == True: ## Moves the bird right and flips its sprite
            bird.x -= Bird_Vel
            pygame.event.post(pygame.event.Event(Switch_Bird_Direction))
        elif bird.x == WIDTH - Bird_Width and bird_facing_left == False: ## Moves the bird left and flips its sprite
            pygame.event.post(pygame.event.Event(Switch_Bird_Direction))
            bird.x += Bird_Vel
        elif bird_facing_left == True: ## Moves the bird left or right depending on the direction it faces
            bird.x -= Bird_Vel
        else:
            bird.x += Bird_Vel
        if (character.colliderect(slime1) or character.colliderect(slime2) or character.colliderect(slime3)) and character_invincibility_frames_counter > Invincibility_Frames: ## If the character collides with the slime, he loses health and is moved in the opposite direction to the one he is facing
            pygame.event.post(pygame.event.Event(Protagonist_Lose_Health))
            pygame.event.post(pygame.event.Event(Reset_Invincibility_Frames_Counter))
            if Protagonist_Facing_Right:
                character.x -= Character_Fallback
                sword.x -= Character_Fallback
            else:
                character.x += Character_Fallback
                sword.x += Character_Fallback
        if projectile_count == 1: ## Spawns the projectile at the place of the bird once the previous projectile has landed
            projectile.x, projectile.y = bird.x, bird.y
            pygame.event.post(pygame.event.Event(Change_Projectile_Count))
        elif projectile_count == 0 and projectile.y < Y_Position: ## Moves a launched projectile straight down
            projectile.y += Projectile_Vel
        else:
            pygame.event.post(pygame.event.Event(Change_Projectile_Count))
        if character.colliderect(projectile) and character_invincibility_frames_counter > Invincibility_Frames: ## Damages the character if hit by a projectile
            character.x -= Character_Fallback*2 ## Increased fallback to avoid taking more than 1 damage from projectile
            sword.x -= Character_Fallback*2
            pygame.event.post(pygame.event.Event(Protagonist_Lose_Health)) ## Protagonist loses health
            pygame.event.post(pygame.event.Event(Reset_Invincibility_Frames_Counter))
        if character.colliderect(heart):
            pygame.event.post(pygame.event.Event(Collect_Heart)) ## Protagonist gains health
    elif level == 2:
        if character.colliderect(dog) and character_invincibility_frames_counter > Invincibility_Frames:
            pygame.event.post(pygame.event.Event(Protagonist_Lose_Health))
            pygame.event.post(pygame.event.Event(Reset_Invincibility_Frames_Counter))
            if Protagonist_Facing_Right: ## Character is pushed back in the opposite direction that he faces when he runs into the dog
                character.x -= Character_Fallback*3
                sword.x -= Character_Fallback*3
            else:
                character.x += Character_Fallback*3
                sword.x += Character_Fallback*3
        if character.x > High_Rock_Path_X_Position - Protagonist_Width and character.y <= High_Rock_Path_Y_Position: ## Checks if the character is in the position on the map that is in the dogs sight
            if dog.x > High_Rock_Path_X_Position: ## After the character is in the dogs sight, he will move toward the character
                pygame.event.post(pygame.event.Event(Dog_Moving_Left))
                dog.x -= Dog_Vel
            else:
                pygame.event.post(pygame.event.Event(Dog_Idle)) ## If the dog reaches the edge of the platform, he will be idle again
        else:
            pygame.event.post(pygame.event.Event(Dog_Idle)) ## If the character leaves the area, the dog will be idle again
        if dog.x + Dog_Width < High_Rock_Path_X_Position:
            if dog.y + Dog_Height < Lava_Y_Position:
                dog.y += Character_Vel
            elif dog_health > 0:
                pygame.event.post(pygame.event.Event(Dog_Lose_Health))
    elif level == 3:
        if character.colliderect(ghost1) and character_invincibility_frames_counter > Invincibility_Frames: ## Character runs into ghost1 and is pushed back in the opposite direction that he faces
            pygame.event.post(pygame.event.Event(Protagonist_Lose_Health))
            pygame.event.post(pygame.event.Event(Reset_Invincibility_Frames_Counter))
            if Protagonist_Facing_Right:
                character.x -= Character_Fallback
                sword.x -= Character_Fallback
            else:
                character.x += Character_Fallback
                sword.x += Character_Fallback
        if character.colliderect(ghost2) and character_invincibility_frames_counter > Invincibility_Frames: ## Character runs into ghost2 and is pushed back in the opposite direction that he faces
            pygame.event.post(pygame.event.Event(Protagonist_Lose_Health))
            pygame.event.post(pygame.event.Event(Reset_Invincibility_Frames_Counter))
            if Protagonist_Facing_Right:
                character.x -= Character_Fallback
                sword.x -= Character_Fallback
            else:
                character.x += Character_Fallback
                sword.x += Character_Fallback
        if phase1_completed:
            if slime1.y < Ground_Height - Slime_Height: ## The height at which the slime looks like it is touching the ground
                slime1.y += Character_Vel
            if slime2.y < Ground_Height - Slime_Height:
                slime2.y += Character_Vel
            if slime3.y < Ground_Height - Slime_Height:
                slime3.y += Character_Vel
            if slime4.y < Ground_Height - Slime_Height:
                slime4.y += Character_Vel
            if slime1.y >= Ground_Height - Slime_Height: ## Once the slime touches the ground, he will be able to move left and right
                if slime1.x >= WIDTH - Slime_Width and Slime1_Facing_Right:
                    pygame.event.post(pygame.event.Event(Change_Slime1_Direction))
                elif slime1.x <= 0 and not Slime1_Facing_Right:
                    pygame.event.post(pygame.event.Event(Change_Slime1_Direction))
                elif Slime1_Facing_Right:
                    slime1.x += Slime_Vel
                else:
                    slime1.x -= Slime_Vel
            if slime2.y >= Ground_Height - Slime_Height:
                if slime2.x >= WIDTH - Slime_Width and Slime2_Facing_Right:
                    pygame.event.post(pygame.event.Event(Change_Slime2_Direction))
                elif slime2.x <= 0 and not Slime2_Facing_Right:
                    pygame.event.post(pygame.event.Event(Change_Slime2_Direction))
                elif Slime2_Facing_Right:
                    slime2.x += Slime_Vel
                else:
                    slime2.x -= Slime_Vel
