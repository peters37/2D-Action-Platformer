## This function handles the player moving left and right, and jumping
def character_movement(keys_pressed, character, rising, grounded, sword, Protagonist_Facing_Right, Current_Ground_Level, Previous_Ground_Level, heart, wall, swing, holding_space):
    if keys_pressed[pygame.K_LEFT] and keys_pressed[pygame.K_RIGHT]: ## If the character presses left and right at the same time, he won't move
        character.x += 0
    elif keys_pressed[pygame.K_LEFT] and character.x - 10 - Character_Vel > 0 and not (character.colliderect(wall) and not Protagonist_Facing_Right): ## Moving Left and making sure the character is not going into the wall. If the character is facing the wall, he will not be allowed to move forward
        character.x -= Character_Vel ## 10 is subtracted here to better represent the characters sprite, rather than the rectangle
        sword.x -= Character_Vel
        if Protagonist_Facing_Right == True and not swing:
            pygame.event.post(pygame.event.Event(Protagonist_Change_Direction))
    elif keys_pressed[pygame.K_RIGHT] and character.x -10 + Character_Vel < WIDTH - Protagonist_Width and not (character.colliderect(wall) and Protagonist_Facing_Right): ## Moving right. Same conditions as moving left
        character.x += Character_Vel ## 10 is subtracted here to better represent the characters sprite, rather than the rectangle
        sword.x += Character_Vel
        if Protagonist_Facing_Right == False and not swing:
            pygame.event.post(pygame.event.Event(Protagonist_Change_Direction))
    if keys_pressed[pygame.K_SPACE] and not grounded and not holding_space: ## The player will not jump if they are holding the space bar after a previous jump
        pygame.event.post(pygame.event.Event(Holding_Space_Change))
    elif not keys_pressed[pygame.K_SPACE] and holding_space: ## If the player is not holding the space bar, the parameter will update to reflect that
        pygame.event.post(pygame.event.Event(Holding_Space_Change))
    if keys_pressed[pygame.K_SPACE] and (rising == False) and (grounded == True) and not holding_space: ## The player has pressed jump and the code is preparing to handle this (the player will not be able to jump until he hits the ground again)
        pygame.time.delay(50) ## amount of milliseconds between jumps
        rising = True
        grounded = False
        pygame.event.post(pygame.event.Event(Grounded_False))
        pygame.event.post(pygame.event.Event(Rising_True))
    if rising == True: ## After pressing jump, the character rises until hitting his jump height
        if character.y > Previous_Ground_Level + Ground_Sprite_Adjustment - Regular_Jump_Height - Protagonist_Height: ## Adding 5 to the ground level here to make sure the coordinates of the bottom of the sprite and the ground lineup
            character.y -= Jump_Vel
            sword.y -= Jump_Vel
        else:
            pygame.event.post(pygame.event.Event(Rising_False))
    if rising == False and character.y < Current_Ground_Level + Ground_Sprite_Adjustment - Protagonist_Height: ## After hitting the max jump height, the character now falls back down, again adding 5 to Ground_Height to make sure sprite hits the grass
        character.y += Jump_Vel
        sword.y += Jump_Vel
        pygame.event.post(pygame.event.Event(Grounded_False)) ## In most cases, grounded is already false, but this covers the case of the player falling off the ledge
    if character.y == Current_Ground_Level + Ground_Sprite_Adjustment - Protagonist_Height and (rising == False): ## Checks if the character is on the ground, which enables the player to jump again, again adding 5 to the ground level to make sure sprite touches the grass
        pygame.event.post(pygame.event.Event(Update_Previous_Ground_Level))
        pygame.event.post(pygame.event.Event(Grounded_True))

def enemy_movement(character, sword, slime1, slime2, slime3, slime4, bird, bird_facing_left, projectile, projectile_count, Protagonist_Facing_Right, heart, level, dog, dog_health, ghost1, Ghost1_Moving_Down, ghost2, Ghost2_Moving_Down, Ghost1_Moving_Left, Ghost2_Moving_Left, phase1_completed, Slime1_Facing_Right, Slime2_Facing_Right, Slime3_Facing_Right, Slime4_Facing_Right, minotaur, phase2_completed, minotaur_attack_frame_counter, minotaur_attacking, Minotaur_Facing_Left, arrow_sign, phase4_completed, character_invincibility_frames_counter): 
