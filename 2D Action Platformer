## This function defines how the ghosts in level 3 will move
def ghost_movement(ghost1, Ghost1_Moving_Down, Ghost1_Moving_Left, ghost2, Ghost2_Moving_Down, Ghost2_Moving_Left):
    if ghost1.x >= (WIDTH - Ghost_Width) and not Ghost1_Moving_Left: ## If ghost hits the end of the screen, he will change directions from right to left
        pygame.event.post(pygame.event.Event(Ghost1_Change_Horizontal_Direction))
        ghost1.x -= Ghost_Vel
    elif ghost1.x <= 0 and Ghost1_Moving_Left: ## Change directions from left to right
        pygame.event.post(pygame.event.Event(Ghost1_Change_Horizontal_Direction))
        ghost1.x += Ghost_Vel
    elif Ghost1_Moving_Left: ## Moving left
        ghost1.x -= Ghost_Vel
    else: ## Moving right
        ghost1.x += Ghost_Vel
    if ghost2.x > WIDTH - Ghost_Width and not Ghost2_Moving_Left:
        pygame.event.post(pygame.event.Event(Ghost2_Change_Horizontal_Direction))
        ghost2.x -= Ghost_Vel
    elif ghost2.x <= 0 and Ghost2_Moving_Left:
        pygame.event.post(pygame.event.Event(Ghost2_Change_Horizontal_Direction))
        ghost2.x += Ghost_Vel
    elif Ghost2_Moving_Left:
        ghost2.x -= Ghost_Vel
    else:
        ghost2.x += Ghost_Vel
    if ghost1.y <= Ghost1_Y_Position and not Ghost1_Moving_Down: ## Moves the ghost up and down from its starting height to the ground level
        pygame.event.post(pygame.event.Event(Ghost1_Change_Vertical_Direction))
    elif ghost1.y >= Ground_Height - Protagonist_Height and Ghost1_Moving_Down:
        pygame.event.post(pygame.event.Event(Ghost1_Change_Vertical_Direction))
    elif Ghost1_Moving_Down:
        ghost1.y += Ghost_Vel
    else:
        ghost1.y -= Ghost_Vel
    if ghost2.y <= Ghost2_Y_Position and not Ghost2_Moving_Down: ## The ghost will change directions once it hits its peak or the ground
        pygame.event.post(pygame.event.Event(Ghost2_Change_Vertical_Direction))
    elif ghost2.y >= Ground_Height - Protagonist_Height and Ghost2_Moving_Down:
        pygame.event.post(pygame.event.Event(Ghost2_Change_Vertical_Direction))
    elif Ghost2_Moving_Down:
        ghost2.y += Ghost_Vel
    else:
        ghost2.y -= Ghost_Vel

